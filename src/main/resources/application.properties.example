# ===========================
# Server
# ===========================
server.port=8080

# ===========================
# Database – MySQL
# ===========================
spring.datasource.url=jdbc:mysql://localhost:3306/smart_campus?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC
spring.datasource.username=${DB_USERNAME:root}
spring.datasource.password=${DB_PASSWORD:}
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect
spring.jpa.properties.hibernate.format_sql=true

# ===========================
# OAuth2 – Google
# Set GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET as environment variables
# Or configure in application-local.properties (add to .gitignore)
# ===========================
spring.security.oauth2.client.registration.google.client-id=${GOOGLE_CLIENT_ID:}
spring.security.oauth2.client.registration.google.client-secret=${GOOGLE_CLIENT_SECRET:}
spring.security.oauth2.client.registration.google.scope=email,profile
spring.security.oauth2.client.registration.google.redirect-uri={baseUrl}/oauth2/callback/{registrationId}

# ===========================
# JWT
# Set JWT_SECRET as environment variable
# ===========================
app.jwt.secret=${JWT_SECRET:}
app.jwt.expiration=86400000

# ===========================
# File Upload (Module C)
# ===========================
spring.servlet.multipart.enabled=true
spring.servlet.multipart.max-file-size=5MB
spring.servlet.multipart.max-request-size=15MB
app.upload.dir=uploads

# ===========================
# CORS
# ===========================
app.cors.allowed-origins=http://localhost:3000,http://localhost:5173

# ===========================
# Logging
# ===========================
logging.level.com.smartcampus=DEBUG
logging.level.org.springframework.security=INFO
